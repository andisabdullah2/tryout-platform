# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tryout_platform?schema=public"
# DIRECT_URL: Koneksi langsung ke PostgreSQL (diperlukan untuk prisma migrate)
# Saat development, biasanya sama dengan DATABASE_URL
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/tryout_platform?schema=public"

# ============================================================
# NEXTAUTH
# ============================================================
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# GOOGLE OAUTH
# ============================================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================================
# EMAIL (RESEND)
# ============================================================
RESEND_API_KEY="re_your_resend_api_key"

# ============================================================
# VIDEO STREAMING (MUX)
# ============================================================
MUX_TOKEN_ID="your-mux-token-id"
MUX_TOKEN_SECRET="your-mux-token-secret"

# ============================================================
# FILE STORAGE (CLOUDFLARE R2)
# ============================================================
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="tryout-platform"

# ============================================================
# PAYMENT GATEWAY (MIDTRANS)
# ============================================================
MIDTRANS_SERVER_KEY="SB-Mid-server-your-server-key"
MIDTRANS_CLIENT_KEY="SB-Mid-client-your-client-key"

# ============================================================
# REAL-TIME (PUSHER)
# ============================================================
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="ap1"

# ============================================================
# CACHE (UPSTASH REDIS)
# ============================================================
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# ============================================================
# PUBLIC ENVIRONMENT VARIABLES (accessible in browser)
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-your-client-key"

# ============================================================
# CRON JOB
# Generate secret: openssl rand -base64 32
# ============================================================
CRON_SECRET="your-cron-secret-here"
