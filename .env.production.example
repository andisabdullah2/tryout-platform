# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES
# Salin file ini ke .env.production dan isi dengan nilai produksi
# JANGAN commit file .env.production ke version control
# ============================================================

# ============================================================
# DATABASE (Production — dengan connection pooling)
# Gunakan Prisma Accelerate atau PgBouncer untuk connection pooling
# ============================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tryout_platform?schema=public&connection_limit=10&pool_timeout=20"
# Untuk Prisma Accelerate, gunakan format berikut:
# DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# DIRECT_URL: Koneksi langsung ke PostgreSQL (diperlukan untuk prisma migrate deploy)
# Saat menggunakan Prisma Accelerate, DATABASE_URL adalah URL Accelerate dan
# DIRECT_URL adalah URL koneksi langsung ke database PostgreSQL.
# Saat menggunakan koneksi langsung, DIRECT_URL sama dengan DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/tryout_platform?schema=public"

# ============================================================
# NEXTAUTH (Production)
# Generate secret: openssl rand -base64 32
# ============================================================
NEXTAUTH_SECRET="GENERATE_STRONG_SECRET_HERE"
NEXTAUTH_URL="https://yourdomain.com"

# ============================================================
# GOOGLE OAUTH (Production)
# Daftarkan di Google Cloud Console dengan redirect URI produksi
# ============================================================
GOOGLE_CLIENT_ID="your-production-google-client-id"
GOOGLE_CLIENT_SECRET="your-production-google-client-secret"

# ============================================================
# EMAIL (RESEND — Production)
# ============================================================
RESEND_API_KEY="re_your_production_resend_api_key"

# ============================================================
# VIDEO STREAMING (MUX — Production)
# ============================================================
MUX_TOKEN_ID="your-production-mux-token-id"
MUX_TOKEN_SECRET="your-production-mux-token-secret"
MUX_WEBHOOK_SECRET="your-mux-webhook-signing-secret"

# ============================================================
# FILE STORAGE (CLOUDFLARE R2 — Production)
# ============================================================
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-production-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-production-r2-secret-access-key"
R2_BUCKET_NAME="tryout-platform-prod"
R2_PUBLIC_URL="https://cdn.yourdomain.com"

# ============================================================
# PAYMENT GATEWAY (MIDTRANS — Production)
# Gunakan Production keys, bukan Sandbox
# ============================================================
MIDTRANS_SERVER_KEY="Mid-server-your-production-server-key"
MIDTRANS_CLIENT_KEY="Mid-client-your-production-client-key"

# ============================================================
# REAL-TIME (PUSHER — Production)
# ============================================================
PUSHER_APP_ID="your-production-pusher-app-id"
PUSHER_KEY="your-production-pusher-key"
PUSHER_SECRET="your-production-pusher-secret"
PUSHER_CLUSTER="ap1"

# ============================================================
# CACHE (UPSTASH REDIS — Production)
# ============================================================
UPSTASH_REDIS_REST_URL="https://your-production-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-production-upstash-token"

# ============================================================
# MONITORING (SENTRY — Production)
# ============================================================
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="tryout-platform"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# ============================================================
# PUBLIC ENVIRONMENT VARIABLES
# ============================================================
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NEXT_PUBLIC_PUSHER_KEY="your-production-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="Mid-client-your-production-client-key"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# ============================================================
# CRON JOB
# Generate secret: openssl rand -base64 32
# ============================================================
CRON_SECRET="your-production-cron-secret"
